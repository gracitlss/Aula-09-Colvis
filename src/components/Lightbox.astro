<div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Galeria de imagens" hidden>
  <div class="lightbox-backdrop" data-close="lightbox"></div>
  <div class="lightbox-panel">
    <button class="modal-close" type="button" aria-label="Fechar galeria" data-close="lightbox">×</button>
    <img id="lightbox-image" src="" alt="" />
    <div class="lightbox-caption">
      <p id="lightbox-caption"></p>
      <div class="lightbox-actions">
        <button type="button" class="button secondary" id="prev-image">Anterior</button>
        <button type="button" class="button secondary" id="next-image">Próximo</button>
      </div>
    </div>
  </div>
</div>

<style>
  .lightbox[hidden] { display: none !important; }
  .lightbox { position: fixed; inset: 0; z-index: 250; display: grid; place-items: center; }
  .lightbox-backdrop { position: absolute; inset: 0; background: rgba(0,0,0,0.84); }
  .lightbox-panel { position: relative; width: min(900px, calc(100% - 2rem)); padding: 1rem; border-radius: 1.25rem; background: rgba(6,10,16,0.95); border: 1px solid var(--border); box-shadow: var(--shadow); }
  .lightbox-panel img { width: 100%; max-height: 70vh; object-fit: contain; border-radius: 1rem; }
  .lightbox-caption { display: flex; justify-content: space-between; gap: 1rem; align-items: center; padding: 1rem 0 0; }
  .lightbox-actions { display: flex; gap: 0.75rem; }
  .button.secondary { background: transparent; color: var(--text); border: 1px solid var(--border); }
  @media (max-width: 720px) {
    .lightbox-caption { flex-direction: column; align-items: flex-start; }
  }
</style>

<script>
  window.addEventListener('DOMContentLoaded', () => {
    const lightbox = document.getElementById('lightbox');
    const imageEl = document.getElementById('lightbox-image');
    const captionEl = document.getElementById('lightbox-caption');
    const buttons = Array.from(document.querySelectorAll('[data-lightbox-image]'));
    const closeButtons = document.querySelectorAll('[data-close="lightbox"]');
    const prevButton = document.getElementById('prev-image');
    const nextButton = document.getElementById('next-image');
    let currentIndex = 0;
    const images = buttons.map((button) => ({ src: button.dataset.lightboxImage || '', alt: button.dataset.lightboxAlt || '' }));

    const openLightbox = (index) => {
      currentIndex = index;
      if (!lightbox || !imageEl || !captionEl) return;
      const image = images[index];
      imageEl.src = image.src;
      imageEl.alt = image.alt;
      captionEl.textContent = image.alt;
      lightbox.removeAttribute('hidden');
      document.body.style.overflow = 'hidden';
    };

    const closeLightbox = () => {
      if (!lightbox) return;
      lightbox.setAttribute('hidden', 'true');
      document.body.style.overflow = '';
    };

    buttons.forEach((button, index) => {
      button.addEventListener('click', () => openLightbox(index));
    });

    prevButton?.addEventListener('click', () => {
      const nextIndex = (currentIndex - 1 + images.length) % images.length;
      openLightbox(nextIndex);
    });

    nextButton?.addEventListener('click', () => {
      const nextIndex = (currentIndex + 1) % images.length;
      openLightbox(nextIndex);
    });

    closeButtons.forEach((button) => button.addEventListener('click', closeLightbox));
    document.addEventListener('keydown', (event) => {
      if (!lightbox || lightbox.hasAttribute('hidden')) return;
      if (event.key === 'Escape') closeLightbox();
      if (event.key === 'ArrowRight') {
        const nextIndex = (currentIndex + 1) % images.length;
        openLightbox(nextIndex);
      }
      if (event.key === 'ArrowLeft') {
        const nextIndex = (currentIndex - 1 + images.length) % images.length;
        openLightbox(nextIndex);
      }
    });
  });
</script>
